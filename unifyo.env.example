# Skopíruj na server (napr. /etc/unifyo/unifyo.env) a doplň hodnoty. Bez tajomstiev v gite.

# APP_BASE_URL=https://unifyo.online
# DB_PATH=/opt/unifyo/app/app.db

# Stripe
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...
# (alternatíva: STRIPE_PRICE_ID_BASIC=price_... — server berie obe)
# Voliteľný fallback, ak STRIPE_PRICE_ID chýba alebo je neplatný:
# DEFAULT_STRIPE_PRICE_ID=price_...

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-5-mini

# SMTP (voliteľné)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=

# ADMIN_EMAILS=ty@example.com
